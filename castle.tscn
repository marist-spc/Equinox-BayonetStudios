[sub_resource type="GDScript" id="GDScript_rfi2n"]
script/source = "extends Node2D

var crossLight = preload(\"res://CrossLight.tscn\")
# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	$Warning.hide()
	$LightCross.hide()
	


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	var playerPos = $Player.position
	
	if playerPos.y >= 150:
		playerPos.y = 844

func crossLaser():
	var attackNum = 8
	
	for attacks in attackNum:
		var playerPos = $\"Player\".global_position
		var warning = $\"Warning\"
		var randX = randf_range(-2000, 2000)

		# Position and show the warning indicator
		warning.position = Vector2(randX, 687)
		warning.show()
		warning.play(\"Warn\")
		
		# Wait for the warning animation to finish
		await get_tree().create_timer(.5).timeout 
		
		warning.stop()
		warning.hide()
		
		# 2. Spawn a completely new attack instance
		var new_attack = crossLight.instantiate()
		get_parent().add_child(new_attack) # Add it to the world
		new_attack.start_attack(randX)     # Trigger its movement
		
		# 3. Optional: Add a small delay before spawning the NEXT warning
		await get_tree().create_timer(0.2).timeout 
			
func targetLock():
	var attackNum = 4
	
	for attacks in attackNum:
		var playerPos = $Player.global_position
		var attackSprite = Sprite2D.new()
		attackSprite.texture = load(\"res://Art/Boss/SpearAttack.png\")
		var randX = randf_range(playerPos.x - 1000, playerPos.x + 1000)
#		-1373, 1838
		if randX:
			$Warning.position = Vector2(playerPos.x, playerPos.y)
			$Warning.show()
			$Warning.play(\"Warn\")
			
			await get_tree().create_timer(.5).timeout 
			
			$Warning.stop()
			$Warning.hide()
			if attacks == 1:
				attackSprite.position = Vector2(-1375, -1000)
				attackSprite.rotation = PI - PI/4
			else:
				attackSprite.position = Vector2(4000, -1000)
				attackSprite.rotation = PI + PI/4
				
			add_child(attackSprite)
			
			var tween = get_tree().create_tween()
			tween.tween_property(attackSprite, \"position\", Vector2(playerPos.x, playerPos.y), 0.50)
			tween.tween_callback(attackSprite.hide.bind())
"

