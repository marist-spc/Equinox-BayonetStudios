[sub_resource type="GDScript" id="GDScript_y2bgq"]
script/source = "extends Node2D

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	var playerPos = $Player.global_position
	print(playerPos)
	
	if playerPos >= Vector2(2300.0, 600.0) and playerPos <= Vector2(2600.0, 1200.0):
		$ColliderL.showMessage(\"The king took my arm...\")
	else:
		$ColliderL.showMessage(\"\")
		
	
	#if playerPos >= Vector2(5400.0, 600.0) and playerPos <= Vector2(5750.0, 1200.0):
		#$Door.showMessage(\"Press 'E' To Start Your Adventure\")
		#if Input.is_action_pressed(\"interact\"):
			#get_tree().change_scene_to_file(\"res://city.tscn\")
	#else:
		#$Door.showMessage(\"\")
		
	
"

