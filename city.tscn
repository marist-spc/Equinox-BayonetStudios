[sub_resource type="GDScript" id="GDScript_y2bgq"]
script/source = "extends Node2D

var box_door
var player_inside_door: bool = false
@onready var camera: Camera2D = $Player/Camera2D

func _ready() -> void:
	$NPC1.hide()
	$NPC2.hide()
	$NPC3.hide()
	$ALL1.hide()
	$ALL2.hide()

func _process(_delta: float) -> void:
	var p = $Player.global_position
	
	if p.x >= 1800 and p.x <= 2800:
		$NPC1.show()
		$NPC1/Label.text = \"The king took my arm!\"
	else:
		$NPC1.hide()
	if p.x >= 4100 and p.x <= 5100:
		$NPC2.show()
		$NPC2/Label.text = \"The king killed my husband!\"
	else:
		$NPC2.hide()
	if p.x >= 6230 and p.x <= 7230:
		$NPC3.show()
		$NPC3/Label.text = \"The king destroyed my roof!\"
	else:
		$NPC3.hide()
	if p.x >= 7800 and p.x <= 8800:
		$ALL1.show()
		$ALL1/Label.text = \"And worst of all...\"
	else:
		$ALL1.hide()
	if p.x >= 9480 and p.x <= 10480:
		$ALL2.show()
		$ALL2/Label.text = \"HE TOOK OUR EARS!!!\"
		teleport_npcs()
	else:
		$ALL2.hide()
	
	# --- Trigger Zone: Castle Door Entry ---
	var in_door_zone = (p.x >= 12424.0 and p.x <= 12717.0) and (p.y >= 400.0 and p.y <= 700.0)
	
	if in_door_zone:
		if not player_inside_door:
			player_inside_door = true
			$Door/Label.text = \"Press 'C' To Enter!\"
		
		# Change scene safely on key tap
		if Input.is_action_just_pressed(\"interact\"):
			get_tree().change_scene_to_file(\"res://castle.tscn\")
	else:
		if player_inside_door:
			player_inside_door = false
			
func teleport_npcs() -> void:
	var npcs = get_tree().get_nodes_in_group(\"NPCs\")
	
	for i in range(npcs.size()):
		var tween = get_tree().create_tween()
		if i == 0:
			tween.tween_property(npcs[i], \"global_position\", Vector2(10025, 900), .4)
		elif i == 1:
			tween.tween_property(npcs[i], \"global_position\", Vector2(10050, 1010), .4)
		elif i == 2:
			tween.tween_property(npcs[i], \"global_position\", Vector2(10000, 1010), .4)
"

