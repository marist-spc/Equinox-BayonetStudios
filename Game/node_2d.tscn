[sub_resource type="GDScript" id="GDScript_rfi2n"]
script/source = "extends Node2D

# Called when the node enters the scene tree for the first time.
func _ready() -> void:
	pass


# Called every frame. 'delta' is the elapsed time since the previous frame.
func _process(_delta: float) -> void:
	var playerPos = $Player.global_position
	#print(playerPos)
	
	if playerPos >= Vector2(2360.0, 600.0) and playerPos <= Vector2(2380.0, 1200.0) or playerPos >= Vector2(5905.0, 600.0) and playerPos <= Vector2(5920.0, 1200.0):
		$ColliderL.showMessage(\"Wouldn't you like to know weather boy...\")
		$ColliderR.showMessage(\"Wouldn't you like to know weather boy...\")
	else:
		$ColliderL.showMessage(\"\")
		$ColliderR.showMessage(\"\")
		
	
	if playerPos >= Vector2(5400.0, 600.0) and playerPos <= Vector2(5750.0, 1200.0):
		$Door.showMessage(\"Press 'E' To Start Your Adventure\")
		if Input.is_action_pressed(\"interact\"):
			get_tree().change_scene_to_file(\"res://city.tscn\")
	else:
		$Door.showMessage(\"\")
		
	
"

